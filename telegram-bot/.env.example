# HERMES Telegram Bot — Environment Variables
# Copy this file to .env and fill in the real values.
# NEVER commit .env to git.

# ── Required ──────────────────────────────────────────────────────────────────

# Your Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Access control ─────────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs allowed to use the bot.
# Find your ID by messaging @userinfobot on Telegram.
# Leave empty to allow all users (not recommended for production).
ADMIN_USER_IDS=your_telegram_user_id_here

# ── Optional overrides ─────────────────────────────────────────────────────────

# Claude model used for skill agents (default: claude-sonnet-4-6)
# Upgrade to claude-opus-4-7 for better Arabic quality; downgrade to claude-haiku-4-5-20251001 to reduce cost.
# CLAUDE_MODEL=claude-sonnet-4-6

# Claude model used for the intent router (default: claude-haiku-4-5-20251001)
# CLAUDE_ROUTER_MODEL=claude-haiku-4-5-20251001

# Max messages kept in memory per user session (default: 20)
# MAX_CONTEXT_MESSAGES=20

# Path to the agents-for-good-gcc repo (used for reference; not read at runtime)
# HERMES_REPO_PATH=~/Documents/agents-for-good-gcc
